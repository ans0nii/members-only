<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Members Only</title>
</head>
<body>
  <h1>Members Only Club</h1>
  
  <nav>
    <% if (user) { %>
      <p>Welcome, <%= user.first_name %>!</p>
      <a href="/new-message">Create New Message</a> |
      
      <% if (!user.is_member) { %>
        <a href="/join-club">Join the Club</a> |
      <% } %>
      
      <a href="/log-out">Log Out</a>
    <% } else { %>
      <a href="/sign-up">Sign Up</a> |
      <a href="/log-in">Log In</a>
    <% } %>
  </nav>

  <hr>

  <h2>Messages</h2>
  
  <% if (messages.length === 0) { %>
    <p>No messages yet. Be the first to post!</p>
  <% } else { %>
    <% messages.forEach(message => { %>
      <div style="border: 1px solid #ccc; padding: 10px; margin: 10px 0;">
        <h3><%= message.title %></h3>
        <p><%= message.text %></p>
        
        <% if (user && user.is_member) { %>
          <p><em>Posted by: <%= message.first_name %> <%= message.last_name %></em></p>
          <p><em><%= new Date(message.timestamp).toLocaleString() %></em></p>
        <% } else { %>
          <p><em> Join the club to see who posted this!</em></p>
        <% } %>
        
        <% if (user && user.is_admin) { %>
          <form action="/messages/<%= message.id %>/delete" method="POST" style="display:inline;">
            <input type="hidden" name="messageId" value="<%= message.id %>">
            <button type="submit">Delete</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  <% } %>
</body>
</html>